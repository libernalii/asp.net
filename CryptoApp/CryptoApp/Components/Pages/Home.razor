@page "/"
@using CryptoApp.Models

<h3 class="mb-4">Crypto Market</h3>

<button class="btn btn-primary mb-3" @onclick="ToggleForm">
    ➕ Add Currency
</button>

@if (showForm)
{
    <div class="card p-3 mb-3 bg-dark text-white">
        <input placeholder="Name" @bind="newCurrency.Name" class="form-control mb-2" />
        <input placeholder="Symbol" @bind="newCurrency.Symbol" class="form-control mb-2" />
        <input placeholder="Price" type="number" @bind="newCurrency.Price" class="form-control mb-2" />
        <input placeholder="Market Cap" type="number" @bind="newCurrency.MarketCap" class="form-control mb-2" />
        <input placeholder="Volume 24h" type="number" @bind="newCurrency.Volume24h" class="form-control mb-2" />
        <input placeholder="Supply" type="number" @bind="newCurrency.Supply" class="form-control mb-2" />

        <button class="btn btn-success" @onclick="AddCurrency">Save</button>
    </div>
}

<table class="table table-dark table-hover align-middle">
    <thead>
        <tr>
            <th>#</th>
            <th>Name</th>
            <th>Price</th>
            <th>1h %</th>
            <th>24h %</th>
            <th>7d %</th>
            <th>Market Cap</th>
            <th>Volume (24h)</th>
            <th>Supply</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var c in currencies)
        {
            <tr>
                <td>@c.Rank</td>

                <td>
                    <b>@c.Name</b>
                    <div class="text-secondary small">@c.Symbol</div>
                </td>

                <td>@FormatMoney(c.Price)</td>

                <td class="@GetColor(c.Change1h)">
                    @c.Change1h %
                </td>

                <td class="@GetColor(c.Change24h)">
                    @c.Change24h %
                </td>

                <td class="@GetColor(c.Change7d)">
                    @c.Change7d %
                </td>

                <td>@FormatMoney(c.MarketCap)</td>

                <td>
                    @FormatMoney(c.Volume24h)
                    <div class="small text-secondary">@c.Symbol</div>
                </td>

                <td>
                    @FormatNumber(c.Supply)
                    <div class="small text-secondary">@c.Symbol</div>
                </td>

                <td>
                    <button class="btn btn-outline-primary btn-sm">
                        Buy
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    List<CryptoCurrency> currencies = new()
    {
        new CryptoCurrency {
            Rank = 1, Name="Bitcoin", Symbol="BTC",
            Price=3066318, Change1h=-0.17m, Change24h=4.65m, Change7d=6.3m,
            MarketCap=6066318659643, Volume24h=81000000000, Supply=19000000
        },
        new CryptoCurrency {
            Rank = 6, Name="USDC", Symbol="USDC",
            Price=43.32m, Change1h=0.01m, Change24h=0.64m, Change7d=0.02m,
            MarketCap=726341824824, Volume24h=50000000000, Supply=50000000000
        }
    };

    CryptoCurrency newCurrency = new();
    bool showForm = false;

    void ToggleForm() => showForm = !showForm;

    void AddCurrency()
    {
        newCurrency.Rank = currencies.Count + 1;
        currencies.Add(newCurrency);
        newCurrency = new CryptoCurrency();
        showForm = false;
    }

    string GetColor(decimal value)
        => value >= 0 ? "text-success" : "text-danger";

    string FormatMoney(decimal value)
        => $"{value:N0} ₴";

    string FormatNumber(decimal value)
        => $"{value:N0}";
}